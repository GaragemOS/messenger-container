# ==========================================================================
# messenger-container — exemplo de variaveis de ambiente.
# Copie para `.env` (local) ou configure no Railway. NUNCA commite o `.env`.
# ==========================================================================

# --- Core ---
NODE_ENV=development
PORT=3000
# URL publica do servico principal (API + console). Sem barra no final.
PUBLIC_BASE_URL=http://localhost:3000
# Origem dedicada que serve o embed (loader.js + documento do iframe).
# Em producao deve ser um subdominio separado, ex.: https://embed.garagem.dev
EMBED_BASE_URL=http://localhost:3000

# --- Banco (Railway injeta DATABASE_URL automaticamente) ---
DATABASE_URL=postgres://user:pass@localhost:5432/messenger
# Liga SSL no driver pg (Railway = true em producao).
DATABASE_SSL=false

# --- Auth do console (restrito ao dominio) ---
AUTH_ALLOWED_DOMAINS=garagem.dev.br
# Pepper usado no HMAC dos codigos de verificacao e (opcional) das senhas.
# Gere com: node -e "console.log(crypto.randomBytes(32).toString('base64url'))"
SESSION_PEPPER=troque-por-32-bytes-aleatorios

# --- E-mail (Resend) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM="Garagem <no-reply@garagem.dev.br>"

# --- Embed token (JWT efemero) ---
# Chave privada Ed25519 em PEM (PKCS8). Gere com o script de setup.
EMBED_JWT_PRIVATE_KEY=
EMBED_JWT_PUBLIC_KEY=
# Tempo de vida do embed token, em segundos.
EMBED_TOKEN_TTL_SECONDS=600

# --- WhatsApp / Meta (Fase 4+, apos aprovacao do app) ---
GRAPH_API_VERSION=v25.0
META_APP_SECRET=
META_SYSTEM_USER_TOKEN=
WEBHOOK_VERIFY_TOKEN=

# --- Normalizador: fallback LLM (opcional, off por padrao) ---
LLM_FALLBACK_ENABLED=false
ANTHROPIC_API_KEY=
LLM_FALLBACK_MODEL=claude-haiku-4-5
